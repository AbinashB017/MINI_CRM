# =============================================================================
# XENO MINI CRM — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- DATABASE (Supabase PostgreSQL) ------------------------------------------
# Transaction Pooler URL — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.pzsrunpspqvrqqjgmwgd:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection URL — used by Prisma CLI for migrations (port 5432)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.pzsrunpspqvrqqjgmwgd.supabase.co:5432/postgres"

# --- AI / LLM (Groq) ---------------------------------------------------------
# Get from https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GROQ_MODEL="llama-3.3-70b-versatile"

# --- JOB QUEUE (Upstash Redis — BullMQ) --------------------------------------
# Get from https://console.upstash.com → your Redis DB → REST API tab
UPSTASH_REDIS_REST_URL="https://your-db-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# --- SERVICE URLS ------------------------------------------------------------
# In development these point to localhost; update to Render URLs in production
CRM_BACKEND_URL="http://localhost:3001"
CHANNEL_STUB_URL="http://localhost:4001"
CRM_WEBHOOK_URL="http://localhost:3001/api/webhooks/receipt"

# --- SERVER PORTS ------------------------------------------------------------
PORT=3001
CHANNEL_STUB_PORT=4001

# --- MISC --------------------------------------------------------------------
NODE_ENV="development"

# --- FRONTEND (Vite — prefix VITE_ so they're exposed to the browser) --------
VITE_API_URL="http://localhost:3001"
