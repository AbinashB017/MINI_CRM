{
  "name": "@xeno-crm/crm-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "dotenv -e .env -- prisma migrate dev",
    "migrate:prod": "dotenv -e .env -- prisma migrate deploy",
    "seed": "dotenv -e .env -- tsx prisma/seed.ts",
    "generate": "prisma generate",
    "studio": "dotenv -e .env -- prisma studio"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@prisma/client": "^5.16.0",
    "bullmq": "^5.12.0",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "express": "^4.19.2",
    "groq-sdk": "^0.7.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.16.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
